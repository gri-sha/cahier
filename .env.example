# Sessions are signed with this. Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical URL in production, e.g. https://cahier.fyi
# Defaults to http://localhost:3000 when unset.
BETTER_AUTH_URL=

# Sign-in emails. Without a key (local dev) the six-digit codes are printed
# to the terminal running `bun dev` instead.
RESEND_API_KEY=
# Sender address, e.g. "cahier <code@cahier.fyi>" once your domain is verified
# in Resend. Defaults to Resend's onboarding sender.
EMAIL_FROM=

# Postgres (Neon on Vercel). Leave unset locally: the app falls back to
# the docker compose Postgres (postgres://cahier:cahier@localhost:5432/cahier).
DATABASE_URL=
